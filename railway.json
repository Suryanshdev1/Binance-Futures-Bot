{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install -r requirements.txt -r web_demo/requirements.txt"
  },
  "deploy": {
    "startCommand": "streamlit run web_demo/app.py --server.port $PORT --server.address 0.0.0.0",
    "healthcheckPath": "/_stcore/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
